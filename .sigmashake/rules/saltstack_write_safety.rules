# saltstack_write_safety.rules
# Technology: saltstack | Capability: write

rule saltstack-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_saltstack_PATTERN"
  MESSAGE "Blocked an unsafe pattern in saltstack. Use the recommended best practices for 2025/2026."
}

rule saltstack-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_saltstack_API"
  MESSAGE "You are using an outdated API for saltstack. Please upgrade to the newer API."
}
